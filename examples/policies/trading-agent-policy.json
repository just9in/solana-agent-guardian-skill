{
  "policy_id": "trading-agent-jupiter-mainnet-v1",
  "network": "mainnet-beta",
  "agent": {
    "name": "research-trading-agent",
    "environment": "production"
  },
  "limits": {
    "max_single_tx_sol": 0.05,
    "max_daily_spend_sol": 0.25,
    "max_slippage_bps": 50,
    "max_balance_percent_per_tx": 10
  },
  "programs": {
    "allow": [
      "jupiter",
      "spl-token",
      "associated-token-account",
      "system-program",
      "compute-budget"
    ],
    "deny_unknown": true
  },
  "tokens": {
    "allow": [
      "SOL",
      "USDC",
      "USDT"
    ],
    "deny_unknown": true
  },
  "approval_required": {
    "new_recipient_above_sol": 0.01,
    "unknown_token": true,
    "amount_over_sol": 0.02,
    "simulation_warnings": true,
    "unknown_cpi": true
  },
  "blocked_actions": [
    "transfer_full_balance",
    "change_authority",
    "program_upgrade",
    "unknown_program_call",
    "high_slippage_swap",
    "policy_update_by_agent"
  ],
  "logging": {
    "store_intent": true,
    "store_unsigned_transaction": true,
    "store_simulation_result": true,
    "store_policy_decision": true,
    "store_approval": true,
    "store_final_signature": true
  }
}
